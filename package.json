{
  "name": "yaara-consortium",
  "version": "1.0.0",
  "description": "Dynamic Yaara Consortium platform app",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node scripts/dev-server.js start",
    "dev:start": "node scripts/dev-server.js start",
    "dev:stop": "node scripts/dev-server.js stop",
    "dev:restart": "node scripts/dev-server.js restart",
    "dev:status": "node scripts/dev-server.js status",
    "django:setup": "python manage.py migrate && python manage.py import_json --clear",
    "django:dev": "python scripts/django-server.py",
    "migrate": "node scripts/migrate.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.699.0",
    "google-auth-library": "^9.15.0",
    "pg": "^8.13.1"
  }
}
